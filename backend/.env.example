# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
APP_NAME="Atoms Demo API"
APP_VERSION="0.1.0"
API_SECRET_KEY="replace-with-a-long-random-secret"
DATABASE_URL="postgresql+asyncpg://atoms:atoms@localhost:5432/atoms_demo"

# ---------------------------------------------------------------------------
# Stage 3 - Real LLM (DeepSeek / Qwen). Set LLM_PROVIDER=mock for keyless dev.
# ---------------------------------------------------------------------------
LLM_PROVIDER="deepseek"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"

# ---------------------------------------------------------------------------
# Stage 4 - Async tasks (Celery + Redis), multimodal providers, MinIO storage
# Start: docker compose up -d redis minio ; celery -A app.workers.celery_app worker -l info
# ---------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
# IMAGE_PROVIDER=qwen uses Alibaba DashScope Tongyi Wanxiang (requires QWEN_API_KEY).
IMAGE_PROVIDER="mock"   # mock | qwen | comfyui | stablediffusion
# MUSIC_PROVIDER=suno needs SUNO_API_KEY; =musicgen needs MUSICGEN_BASE_URL.
MUSIC_PROVIDER="mock"   # mock | suno | musicgen
COMFYUI_BASE_URL=""
STABLEDIFFUSION_BASE_URL=""
SUNO_API_KEY=""
QWEN_IMAGE_MODEL="wanx2.1-t2i-turbo"
MUSICGEN_BASE_URL=""
# MINIO_ENDPOINT: reachable from the server/worker process (inside Docker: minio:9000).
MINIO_ENDPOINT="localhost:9100"
# MINIO_PUBLIC_ENDPOINT: reachable from the browser; used only to sign presigned URLs.
MINIO_PUBLIC_ENDPOINT="localhost:9100"
MINIO_ACCESS_KEY="atoms"
MINIO_SECRET_KEY="atoms123456"
MINIO_BUCKET="atoms-artifacts"
MINIO_SECURE="false"
# Fixed region keeps presigned-URL signing offline (avoids a region-discovery
# network call to the public endpoint, which would hang inside containers).
MINIO_REGION="us-east-1"
PUBLIC_MEDIA_BASE_URL="http://localhost:9100"

# ---------------------------------------------------------------------------
# Stage 5 - Docker code sandbox (requires access to the Docker daemon).
# The backend process must be able to reach /var/run/docker.sock.
# ---------------------------------------------------------------------------
SANDBOX_ENABLED="true"
SANDBOX_STATIC_IMAGE="nginx:1.27-alpine"
SANDBOX_NODE_IMAGE="node:20-alpine"
SANDBOX_PYTHON_IMAGE="python:3.11-slim"
SANDBOX_MEM_LIMIT="512m"
SANDBOX_CPUS="0.5"
SANDBOX_NETWORK_DISABLED="true"
SANDBOX_TIMEOUT_SECONDS="600"
SANDBOX_PORT_START="18000"
SANDBOX_PORT_END="18100"
SANDBOX_PUBLIC_HOST="localhost"

# ---------------------------------------------------------------------------
# Stage 7 - Vector search (Qdrant). Start: docker compose up -d qdrant
# ---------------------------------------------------------------------------
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="artworks"
EMBEDDING_PROVIDER="mock"   # mock | qwen
EMBEDDING_DIM="1024"

# ---------------------------------------------------------------------------
# Stage 8 - Security / observability
# ---------------------------------------------------------------------------
RATE_LIMIT_DEFAULT="120/minute"
RATE_LIMIT_GENERATE="20/minute"
MAX_UPLOAD_MB="10"
ENABLE_METRICS="false"
ENABLE_TRACING="false"
OTEL_EXPORTER_ENDPOINT=""

# ---------------------------------------------------------------------------
# Stage 9 - Billing / admin / payments
# ADMIN_EMAILS is a JSON list, e.g. ADMIN_EMAILS='["admin@atoms.local"]'
# ---------------------------------------------------------------------------
ADMIN_EMAILS='[]'
CREDIT_COST_CODE="1"
CREDIT_COST_IMAGE="5"
CREDIT_COST_MUSIC="10"
STRIPE_API_KEY=""
STRIPE_WEBHOOK_SECRET=""
WECHAT_PAY_KEY=""
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
